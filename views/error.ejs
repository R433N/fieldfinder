<% layout ('layouts/boilerplate') %>
<div class="row">
    <div class="col-6 offset-3 mt-5">
        <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading"><%=err.statusCode %> Error</h4>
        <p><%= err.message %></p>
        <hr>
        <p class="mb-0">Please check the URL and try again.</p>
        <p><%=err.stack %></p>
        </div>
    </div>
</div>
