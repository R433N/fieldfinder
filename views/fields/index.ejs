<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fields</title>
</head>
<body>
    <h1>All Fields</h1>
    <div>
        <a href="/fields/new">Add Field</a>
    </div>
    <ul>
        <% for(let field of fields ){%>
            <li><a href="/fields/<%= field._id%>"><%= field.title%></a></li>
       <% } %>
    </ul>
</body>
</html>