<% layout ('layouts/boilerplate') %>
    <div class="row">
        <h1 class="text-center">New Field</h1>
        <div class="col-6 offset-3">
            <form action="/fields" method="POST" novalidate enctype="multipart/form-data">
                <div class="mb-3">
                    <label class= "form-label"for="title">Title</label>
                    <input class="form-control" type="text" id = "title" name="field[title]" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Field name is required!</div>
            </div>
            <div class="mb-3">
                <label class= "form-label" for="location">Location</label>
                <input class="form-control" type="text" id="location" name="field[location]" required>
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">Location is required!</div>
            </div>
            <!-- <div class="mb-3">
                <label class= "form-label" for="image">Image URL</label>
                <input class="form-control" type="text" id="image" name="field[image]" required>
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">Please provide an Image URL.</div>
            </div> -->


            <div class="mb-3">
                <label class= "form-label" for="fieldType">Field Type</label>
                <input class="form-control" type="text" id="fieldType" name="field[fieldType]" required>

                <div class="invalid-feedback">Field Type is required!</div>
                <div class="valid-feedback">Looks good!</div>
            </div>

            <div class="mb-3">
                <label class= "form-label" for="phone">Phone Number</label>
                <input class="form-control" type="text" id="phone" name="field[phone]" placeholder="(123)-456-7890" required>
                <div class="invalid-feedback">Type N/A if unapplicable.</div>
            </div>
            <div class="input-group mb-3">
                <label class="btn btn-outline-secondary mb-0" for="image">Browse</label>
                <label class="form-control text-muted mb-0" for="image" id="file-label">Choose Image(s)</label>
                <input class="d-none" type="file" id="image" name="image" multiple 
                    onchange="document.getElementById('file-label').innerText = Array.from(this.files).map(f => f.name).join(', ') || 'Choose Image(s)'">
            </div>

            <div class="mb-3">
              <button class="btn btn-success">Add Field Location</button>
            </div>
            <a href="/fields">All Fields</a>
            </form>

            

        </div>
    </div>