<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Show</title>
</head>
<body>
    <h1><%=field.title %></h1>
    <h2><%=field.location %></h2>
    <p>
        <form action="/fields/<%=field._id%>?_method=DELETE" method="POST">
            <button>DELETE</button>
        </form>
    </p>
    <footer>
        <a href="/fields">All Fields</a>
        <a href="/fields/<%= field._id%>/edit">Edit</a>
